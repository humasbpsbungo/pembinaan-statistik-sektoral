---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Daftar Akun">
  <section class="section auth-section">
    <div class="container">
      <div class="auth-card glass-card animate-fadeInUp">
        <div class="auth-card-content">
          <div class="auth-header">
            <span class="auth-icon">📝</span>
            <h1>Daftar Akun <span class="accent-text">EPSS 2026</span></h1>
            <p>Buat akun untuk menyimpan simulasi dan mengelola bukti dukung instansi Anda secara terintegrasi.</p>
            
            <div class="auth-footer-inline">
              <p>Sudah punya akun? <br/> <a href="/login" class="accent-link">Masuk sekarang</a></p>
            </div>
          </div>
          
          <div class="auth-form-container">
            <form id="registerForm" class="auth-form">
              <div class="form-grid">
                <div class="form-group full-width">
                  <label class="form-label" for="namaInstansi">Nama Instansi</label>
                  <input type="text" id="namaInstansi" class="form-input" placeholder="Pemerintah Kabupaten Bungo/Kementerian Keuangan" required />
                </div>
                
                <div class="form-group">
                  <label class="form-label" for="jenisInstansi">Jenis Instansi</label>
                  <select id="jenisInstansi" class="form-select" required>
                    <option value="">Pilih...</option>
                    <option value="kementerian_lembaga">Kementerian/Lembaga</option>
                    <option value="provinsi">Pemerintah Provinsi</option>
                    <option value="kabupaten">Pemerintah Kabupaten</option>
                    <option value="kota">Pemerintah Kota</option>
                  </select>
                </div>

                <div class="form-group">
                  <label class="form-label" for="namaKontak">Nama Kontak</label>
                  <input type="text" id="namaKontak" class="form-input" placeholder="Nama lengkap" required />
                </div>

                <div class="form-group">
                  <label class="form-label" for="email">Email</label>
                  <input type="email" id="email" class="form-input" placeholder="email@instansi.go.id" required />
                </div>

                <div class="form-group">
                  <label class="form-label" for="password">Password</label>
                  <input type="password" id="password" class="form-input" placeholder="Minimal 6 karakter" required minlength="6" />
                </div>
              </div>

              <div id="errorMsg" class="error-msg" style="display:none"></div>
              <div id="successMsg" class="success-msg" style="display:none"></div>
              
              <button type="submit" class="btn btn-primary btn-lg" style="width:100%">Daftar Akun</button>

              <div class="auth-divider">
                <span>Atau</span>
              </div>
              
              <button type="button" id="googleLoginBtn" class="btn btn-secondary btn-lg btn-google" style="width:100%">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-right: 8px;">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Daftar dengan Google
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('registerForm') as HTMLFormElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
  const successMsg = document.getElementById('successMsg') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.style.display = 'none';
    successMsg.style.display = 'none';

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const namaInstansi = (document.getElementById('namaInstansi') as HTMLInputElement).value;
    const jenisInstansi = (document.getElementById('jenisInstansi') as HTMLSelectElement).value;
    const namaKontak = (document.getElementById('namaKontak') as HTMLInputElement).value;

    const { data, error } = await supabase.auth.signUp({ email, password });
    
    if (error) {
      errorMsg.textContent = error.message;
      errorMsg.style.display = 'block';
      return;
    }

    if (data.user) {
      const { error: profileError } = await supabase.from('profiles').insert({
        id: data.user.id,
        nama_instansi: namaInstansi,
        jenis_instansi: jenisInstansi,
        nama_kontak: namaKontak,
        email: email,
      });

      if (profileError) {
        errorMsg.textContent = 'Akun berhasil dibuat, tetapi gagal menyimpan profil: ' + profileError.message;
        errorMsg.style.display = 'block';
      } else {
        successMsg.textContent = 'Akun berhasil dibuat! Silakan cek email untuk verifikasi, lalu masuk.';
        successMsg.style.display = 'block';
        form.reset();
      }
    }
  });

  const googleLoginBtn = document.getElementById('googleLoginBtn');
  googleLoginBtn?.addEventListener('click', async () => {
    errorMsg.style.display = 'none';
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: window.location.origin + '/auth/callback'
      }
    });
    
    if (error) {
      errorMsg.textContent = error.message;
      errorMsg.style.display = 'block';
    }
  });
</script>

<style>
  .auth-section {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--header-height));
    padding: var(--space-2xl) 0;
  }

  .auth-card {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 0;
    overflow: hidden;
  }

  .auth-card-content {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    min-height: 520px;
  }

  .auth-header {
    background: rgba(255, 255, 255, 0.03);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: left;
    border-right: 1px solid var(--border-color);
  }

  .auth-form-container {
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .auth-icon { font-size: 3rem; display: block; margin-bottom: var(--space-lg); }
  .auth-header h1 { font-size: 1.8rem; margin-bottom: var(--space-md); line-height: 1.2; }
  .auth-header p { color: var(--text-secondary); font-size: 1rem; line-height: 1.6; margin-bottom: var(--space-2xl); }

  .auth-footer-inline {
    margin-top: auto;
  }
  
  .auth-footer-inline p {
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  .accent-link {
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .full-width {
    grid-column: 1 / -1;
  }

  .error-msg {
    padding: var(--space-md);
    background: rgba(248, 81, 73, 0.1);
    border: 1px solid rgba(248, 81, 73, 0.3);
    border-radius: var(--radius-sm);
    color: var(--level-1);
    font-size: 0.85rem;
  }

  .success-msg {
    padding: var(--space-md);
    background: rgba(63, 185, 80, 0.1);
    border: 1px solid rgba(63, 185, 80, 0.3);
    border-radius: var(--radius-sm);
    color: var(--level-5);
    font-size: 0.85rem;
  }

  .auth-divider {
    display: flex;
    align-items: center;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin: var(--space-xs) 0;
  }
  
  .auth-divider::before,
  .auth-divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid var(--border-color);
  }

  .auth-divider span {
    padding: 0 var(--space-md);
  }

  .btn-google {
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    color: #333;
    border: 1px solid #ddd;
  }
  .btn-google:hover {
    background: #f1f1f1;
    border-color: #ccc;
  }

  @media (max-width: 860px) {
    .auth-card-content { grid-template-columns: 1fr; }
    .auth-header { border-right: none; border-bottom: 1px solid var(--border-color); padding: var(--space-xl); }
    .auth-form-container { padding: var(--space-xl); }
    .auth-footer-inline { margin-top: var(--space-lg); }
  }

  @media (max-width: 480px) {
    .form-grid { grid-template-columns: 1fr; }
  }
</style>
