---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Masuk">
  <section class="section auth-section">
    <div class="container">
      <div class="auth-card glass-card animate-fadeInUp">
        <div class="auth-card-content">
          <div class="auth-header">
            <span class="auth-icon">🔐</span>
            <h1>Masuk ke <span class="accent-text">EPSS 2026</span></h1>
            <p>Masuk untuk menyimpan simulasi dan mengelola bukti dukung instansi Anda.</p>
            
            <div class="auth-footer-inline">
              <p>Belum punya akun? <br/> <a href="/register" class="accent-link">Daftar sekarang</a></p>
            </div>
          </div>
          
          <div class="auth-form-container">
            <form id="loginForm" class="auth-form">
              <div class="form-group">
                <label class="form-label" for="email">Email</label>
                <input type="email" id="email" class="form-input" placeholder="email@instansi.go.id" required />
              </div>
              <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input type="password" id="password" class="form-input" placeholder="Masukkan password" required />
              </div>
              <div id="errorMsg" class="error-msg" style="display:none"></div>
              <button type="submit" class="btn btn-primary btn-lg" style="width:100%">Masuk</button>

              <div class="auth-divider">
                <span>Atau</span>
              </div>
              
              <button type="button" id="googleLoginBtn" class="btn btn-secondary btn-lg btn-google" style="width:100%">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-right: 8px;">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Masuk dengan Google
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('loginForm') as HTMLFormElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.style.display = 'none';
    
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    const { error } = await supabase.auth.signInWithPassword({ email, password });
    
    if (error) {
      errorMsg.textContent = error.message;
      errorMsg.style.display = 'block';
    } else {
      window.location.href = '/bukti-dukung';
    }
  });

  const googleLoginBtn = document.getElementById('googleLoginBtn');
  googleLoginBtn?.addEventListener('click', async () => {
    errorMsg.style.display = 'none';
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: window.location.origin + '/auth/callback'
      }
    });
    
    if (error) {
      errorMsg.textContent = error.message;
      errorMsg.style.display = 'block';
    }
  });
</script>

<style>
  .auth-section {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - var(--header-height)); 
  }

  .auth-card {
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
    padding: 0;
    overflow: hidden;
  }

  .auth-card-content {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    min-height: 480px;
  }

  .auth-header {
    background: rgba(255, 255, 255, 0.03);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: left;
    border-right: 1px solid var(--border-color);
  }

  .auth-form-container {
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .auth-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--space-lg);
  }

  .auth-header h1 { font-size: 1.8rem; margin-bottom: var(--space-md); line-height: 1.2; }

  .auth-header p {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: var(--space-2xl);
  }

  .auth-footer-inline {
    margin-top: auto;
  }
  
  .auth-footer-inline p {
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  .accent-link {
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .error-msg {
    padding: var(--space-md);
    background: rgba(248, 81, 73, 0.1);
    border: 1px solid rgba(248, 81, 73, 0.3);
    border-radius: var(--radius-sm);
    color: var(--level-1);
    font-size: 0.85rem;
  }

  .auth-divider {
    display: flex;
    align-items: center;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin: var(--space-xs) 0;
  }
  
  .auth-divider::before,
  .auth-divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid var(--border-color);
  }

  .auth-divider span {
    padding: 0 var(--space-md);
  }

  .btn-google {
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    color: #333;
    border: 1px solid #ddd;
  }
  .btn-google:hover {
    background: #f1f1f1;
    border-color: #ccc;
  }

  @media (max-width: 768px) {
    .auth-card-content { grid-template-columns: 1fr; }
    .auth-header { border-right: none; border-bottom: 1px solid var(--border-color); padding: var(--space-xl); }
    .auth-form-container { padding: var(--space-xl); }
    .auth-footer-inline { margin-top: var(--space-lg); }
  }
</style>
