---
import Layout from '../layouts/Layout.astro';
import SimulasiPanel from '../components/SimulasiPanel';
---

<Layout title="Simulasi IPS">
  <section class="section page-top">
    <div class="container-fluid px-4">
      <div class="breadcrumb animate-fadeInUp">
        <a href="/">Beranda</a> <span>/</span> <span>Simulasi IPS</span>
      </div>

      <div class="section-header animate-fadeInUp stagger-1">
        <h1>Simulasi <span class="accent-text">Indeks Pembangunan Statistik</span></h1>
        <p class="section-desc">
          Pilih level kematangan (1–5) untuk masing-masing indikator dan lihat estimasi IPS secara real-time.
        </p>
      </div>

      <SimulasiPanel client:load />
    </div>
  </section>
</Layout>

<style>
  .page-top { padding-top: var(--space-xl); }
  .px-4 { padding-left: 1rem; padding-right: 1rem; max-width: 1500px; margin: 0 auto; }

  .breadcrumb {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .breadcrumb a { color: var(--text-secondary); }

  .section-header { margin-bottom: var(--space-xl); }
  .section-header h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .section-desc { color: var(--text-secondary); font-size: 1rem; max-width: 800px; }

  /* SimulasiPanel component styles */
  :global(.sim-container) {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  :global(.sim-result-bar) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) var(--space-xl);
    background: var(--gradient-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    position: sticky;
    top: var(--header-height);
    z-index: 10;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  :global(.ips-display) {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  :global(.ips-label) {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  :global(.ips-value) {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
  }

  :global(.ips-predikat) {
    padding: 6px 16px;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 700;
    font-family: var(--font-heading);
  }

  :global(.quick-actions) {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  :global(.set-semua-group) {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  :global(.rekap-btn) {
    padding-left: var(--space-lg);
    border-left: 1px solid var(--border-color);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin-left: var(--space-sm);
    padding-right: var(--space-lg);
  }

  :global(.qa-label) {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  :global(.level-btn-sm) {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    border: none;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  :global(.level-btn-sm:hover) {
    transform: scale(1.1);
    filter: brightness(1.3);
  }

  :global(.sim-body) {
    display: block; /* Formerly 2 columns */
    width: 100%;
  }

  /* Left panel (Now main area) */
  :global(.sim-left) {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* Modal Styles */
  :global(.sim-modal-overlay) {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
  }

  :global(.sim-modal-content) {
    background: var(--bg-body);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-xl);
    width: 100%;
    max-width: 1100px;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  :global(.sim-modal-header) {
    padding: var(--space-lg) var(--space-xl);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--bg-card);
  }

  :global(.sim-modal-header h3) {
    font-size: 1.2rem;
    margin: 0;
  }

  :global(.sim-modal-overlay.small) {
    background: rgba(0, 0, 0, 0.7);
  }

  :global(.sim-modal-content.confirm) {
    max-width: 450px;
    padding: var(--space-xl);
    text-align: center;
    gap: var(--space-md);
  }

  :global(.confirm-icon) {
    font-size: 3.5rem;
    margin-bottom: var(--space-sm);
  }

  :global(.confirm-actions) {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  :global(.badge) {
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 700;
  }

  :global(.modal-close) {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 2rem;
    cursor: pointer;
    line-height: 1;
    transition: color var(--transition-fast);
  }
  :global(.modal-close:hover) { color: var(--text-primary); }

  :global(.sim-modal-body) {
    padding: var(--space-xl);
    overflow-y: auto;
    background: var(--gradient-hero);
  }

  :global(.sim-modal-grid) {
    display: grid;
    grid-template-columns: 350px 1fr 350px;
    gap: var(--space-xl);
    align-items: start;
  }

  :global(.modal-ips-summary) {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  :global(.ips-card.larger) {
    background: var(--bg-card);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-accent);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    box-shadow: var(--shadow-glow);
  }

  :global(.ips-card.larger .ips-value) {
    font-size: 4rem;
    line-height: 1;
  }

  :global(.modal-section) {
    /* reuse card styles but maybe adjust for modal */
  }

  :global(.modal-scroll-area) {
    max-height: 500px;
    overflow-y: auto;
    padding-right: var(--space-sm);
  }

  :global(.modal-scroll-area::-webkit-scrollbar) { width: 4px; }
  :global(.modal-scroll-area::-webkit-scrollbar-thumb) {
    background: var(--border-color);
    border-radius: 2px;
  }

  :global(.sim-modal-footer) {
    padding: var(--space-lg) var(--space-xl);
    border-top: 1px solid var(--border-color);
    display: flex;
    justify-content: flex-end;
    gap: var(--space-md);
    background: var(--bg-card);
  }

  :global(.domain-tabs) {
    display: flex;
    gap: var(--space-sm);
    overflow-x: auto;
    padding-bottom: var(--space-xs);
  }

  :global(.domain-tab) {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-family: var(--font-heading);
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  :global(.domain-tab:hover) {
    border-color: var(--accent);
    color: var(--text-primary);
  }

  :global(.domain-tab.active) {
    background: var(--accent-soft);
    border-color: var(--accent);
    color: var(--accent);
  }

  :global(.dt-icon) { font-size: 1.1rem; }
  :global(.dt-score) { font-family: var(--font-mono); font-size: 0.8rem; }

  :global(.domain-quick-set) {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  :global(.indicators-list) {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  :global(.ind-row) {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--transition-fast);
  }

  :global(.ind-row:hover) { border-color: rgba(212, 168, 67, 0.2); }

  :global(.ind-row-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    gap: var(--space-md);
  }

  :global(.ind-row-left) {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex: 1;
    min-width: 0;
  }

  :global(.ind-kode) {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 3px 8px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  :global(.ind-row-info) {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  :global(.ind-row-name) {
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.ind-row-weight) {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  :global(.ind-row-detail) {
    padding: var(--space-md) var(--space-lg);
    background: var(--bg-dark);
    border-top: 1px solid var(--border-color);
  }

  :global(.ind-row-desc) {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  :global(.ind-current-level) {
    padding: var(--space-md);
    background: rgba(212, 168, 67, 0.05);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
  }

  :global(.ind-current-level strong) {
    display: block;
    margin-bottom: var(--space-xs);
    font-size: 0.9rem;
  }

  :global(.ind-current-level p) {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: var(--space-sm);
  }

  :global(.ind-current-level ul) {
    list-style: none;
    padding: 0;
  }

  :global(.ind-current-level li) {
    font-size: 0.8rem;
    color: var(--text-muted);
    padding-left: 14px;
    position: relative;
  }

  :global(.ind-current-level li::before) {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  /* Right panel */
  :global(.sim-right) {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    position: sticky;
    top: calc(var(--header-height) + 90px);
  }

  :global(.chart-card),
  :global(.breakdown-card),
  :global(.gap-card) {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }

  :global(.chart-card h3),
  :global(.breakdown-card h3),
  :global(.gap-card h3) {
    font-size: 0.9rem;
    margin-bottom: var(--space-md);
    color: var(--text-secondary);
  }

  :global(.chart-wrapper) {
    height: 260px;
    position: relative;
  }

  :global(.breakdown-row) { margin-bottom: var(--space-md); }
  :global(.breakdown-row:last-child) { margin-bottom: 0; }

  :global(.br-header) {
    display: flex;
    justify-content: space-between;
    margin-bottom: 4px;
  }

  :global(.br-name) {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  :global(.br-score) {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
  }

  :global(.gap-list) {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  :global(.gap-item) {
    display: grid;
    grid-template-columns: 50px 1fr 50px 30px;
    gap: var(--space-sm);
    align-items: center;
    font-size: 0.8rem;
    padding: 6px 0;
    border-bottom: 1px solid var(--border-color);
  }

  :global(.gap-item:last-child) { border-bottom: none; }

  :global(.gap-kode) {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 0.75rem;
  }

  :global(.gap-name) {
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.gap-weight) {
    font-family: var(--font-mono);
    color: var(--text-muted);
    font-size: 0.75rem;
    text-align: right;
  }

  :global(.gap-level) {
    font-family: var(--font-heading);
    font-weight: 700;
    text-align: center;
  }

  /* Responsive — tablet and below */
  @media (max-width: 1024px) {
    :global(.sim-body) {
      grid-template-columns: 1fr;
    }
    :global(.sim-right) {
      position: static;
    }
    /* On tablet, show chart side by side with breakdown */
    :global(.sim-right) {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-md);
    }
    :global(.gap-card) {
      grid-column: 1 / -1;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    :global(.sim-result-bar) {
      padding: var(--space-md);
      gap: var(--space-sm);
      top: var(--header-height);
    }
    :global(.ips-display) { gap: var(--space-sm); }
    :global(.ips-value) { font-size: 2rem; }
    :global(.ips-label) { font-size: 0.78rem; }
    :global(.ips-predikat) { padding: 4px 12px; font-size: 0.78rem; }

    :global(.quick-actions) { flex-wrap: wrap; gap: 6px; }
    :global(.level-btn-sm) { width: 34px; height: 34px; font-size: 0.9rem; }

    /* Domain tabs: horizontal scroll, snap */
    :global(.domain-tabs) {
      gap: var(--space-xs);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 2px;
    }
    :global(.domain-tabs::-webkit-scrollbar) { display: none; }
    :global(.domain-tab) {
      flex-shrink: 0;
      scroll-snap-align: start;
      padding: 8px 12px;
      font-size: 0.78rem;
      gap: 6px;
    }
    :global(.dt-name) { max-width: 80px; overflow: hidden; text-overflow: ellipsis; }

    :global(.domain-quick-set) { flex-wrap: wrap; font-size: 0.75rem; }
    :global(.domain-quick-set span) { width: 100%; }

    /* Indicator row: stack name on top, level buttons below */
    :global(.ind-row-header) {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
      padding: var(--space-sm) var(--space-md);
    }
    :global(.ind-row-left) { width: 100%; }
    :global(.ind-row-name) { white-space: normal; font-size: 0.82rem; }
    :global(.ind-kode) { font-size: 0.72rem; }

    /* Level selector: stretch full width */
    :global(.level-selector) {
      width: 100%;
      gap: 6px;
    }
    :global(.level-btn) {
      flex: 1;
      width: auto;    /* override fixed 44px so flex:1 works */
      min-width: 0;
      height: 36px;
    }

    /* Indicator detail */
    :global(.ind-row-detail) { padding: var(--space-md); }

    /* Right panel: single column on mobile */
    :global(.sim-right) {
      display: flex;
      flex-direction: column;
    }
    :global(.chart-wrapper) { height: 200px; }

    /* Gap item: simpler 3 column on mobile */
    :global(.gap-item) {
      grid-template-columns: 45px 1fr 40px;
    }
    :global(.gap-level) { display: none; }
  }

  @media (max-width: 480px) {
    :global(.ips-value) { font-size: 1.7rem; }
    :global(.domain-tab) { padding: 7px 10px; font-size: 0.72rem; }
    :global(.dt-score) { display: none; }
    :global(.level-btn-sm) { width: 30px; height: 30px; font-size: 0.8rem; }
  }
</style>
